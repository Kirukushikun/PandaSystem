# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
APP_NAME=PANDASystem
APP_ENV=production              # local | staging | production
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

BCRYPT_ROUNDS=12                # increase for stronger hashing (costs more CPU)

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # debug | info | notice | warning | error | critical

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_DUMP_BINARY_PATH=/usr/bin    # Windows example: C:\laragon\bin\mysql\mysql-8.0.30-winx64\bin
DB_CONNECTION=mysql
DB_HOST=db                      # use 127.0.0.1 if not running in Docker
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

DB_DATABASE2=                   # secondary database if needed

# ─────────────────────────────────────────
# AUTH API
# ─────────────────────────────────────────
AUTH_API_BASE_URI=https://your-auth-domain.com
AUTH_API_KEY=your_auth_api_key
AUTH_USER_API_KEY=your_auth_user_api_key

ROOT_DOMAIN=https://your-auth-domain.com
MASTER_LOGIN=https://your-auth-domain.com

# ─────────────────────────────────────────
# API SLUGS
# ─────────────────────────────────────────
USERS_API_SLUG="/api/users/xxx/"
USER_DETAILS_SLUG="/api/user/get-details/"
FARMS_API_SLUG="/api/farms/query-get"
FARM_DETAILS_SLUG="/api/farm/get-details/"
DEPARTMENTS_API_SLUG="/api/departments/query-get"
DEPARTMENT_DETAILS_SLUG="/api/department/get-details/"
SECTIONS_API_SLUG="/api/sections/query-get"
SECTION_DETAILS_SLUG="/api/section/get-details/"

# ─────────────────────────────────────────
# SESSION
# ─────────────────────────────────────────
SESSION_DRIVER=file             # file | cookie | database | redis
SESSION_LIFETIME=120            # minutes

# ─────────────────────────────────────────
# CACHE / QUEUE / BROADCAST
# ─────────────────────────────────────────
BROADCAST_DRIVER=log            # log | pusher | ably | redis | null
FILESYSTEM_DISK=local           # local | public | s3
QUEUE_CONNECTION=sync           # sync | database | redis | sqs
CACHE_DRIVER=file               # database | redis | file | memcached

# ─────────────────────────────────────────
# MEMCACHED (only if CACHE_DRIVER=memcached)
# ─────────────────────────────────────────
MEMCACHED_HOST=127.0.0.1

# ─────────────────────────────────────────
# REDIS (only if using redis for cache/queue)
# ─────────────────────────────────────────
REDIS_HOST=redis                # use 127.0.0.1 if not running in Docker
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
MAIL_MAILER=smtp                # smtp | mailgun | ses | postmark | sendmail | log
MAIL_HOST=mailhog               # use mailhog for local, real SMTP host for production
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# AWS S3 (only if FILESYSTEM_DISK=s3)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────
# PUSHER (only if BROADCAST_DRIVER=pusher)
# ─────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ─────────────────────────────────────────
# GOOGLE DRIVE — Spatie Backup (coming soon)
# ─────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=         # OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_DRIVE_CLIENT_SECRET=     # OAuth 2.0 Client Secret
GOOGLE_DRIVE_REFRESH_TOKEN=     # Generate via OAuth playground or artisan command
GOOGLE_DRIVE_FOLDER="Your Backup Folder/SubFolder"

# ─────────────────────────────────────────
# VITE
# ─────────────────────────────────────────
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
